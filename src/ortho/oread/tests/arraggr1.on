  ];

CONSTANT _UI00000000 := [10]{__ghdl_char'[110], __ghdl_char'[101],
   __ghdl_char'[115], __ghdl_char'[116], __ghdl_char'[49], __ghdl_char'[46],
   __ghdl_char'[118], __ghdl_char'[104], __ghdl_char'[100], __ghdl_char'[0]};
