TYPE int IS SIGNED (32);

PUBLIC FUNCTION smod (a : int; b : int) RETURN int
DECLARE
BEGIN
  RETURN a MOD# b;
END;

PUBLIC FUNCTION do_m3_m3 () RETURN int
DECLARE
BEGIN
  RETURN -3 MOD# -3;
END;

PUBLIC FUNCTION do_m3_m2 () RETURN int
DECLARE
BEGIN
  RETURN -3 MOD# -2;
END;

PUBLIC FUNCTION do_11_5 () RETURN int
DECLARE
BEGIN
  RETURN 11 MOD# 5;
END;

PUBLIC FUNCTION do_m11_5 () RETURN int
DECLARE
BEGIN
  RETURN -11 MOD# 5;
END;

