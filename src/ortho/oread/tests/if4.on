TYPE __ghdl_bool_type IS BOOLEAN {false, true};
TYPE __ghdl_integer IS SIGNED (32);

PUBLIC FUNCTION test_arg (b1 : __ghdl_bool_type;
                          b2 : __ghdl_bool_type;
                          b3 : __ghdl_bool_type) RETURN __ghdl_integer
DECLARE
  LOCAL VAR r : __ghdl_integer;
BEGIN
  r := __ghdl_integer'[0];
  IF b1 THEN
   IF b2 THEN
     DECLARE
       LOCAL VAR w : __ghdl_integer;
     BEGIN
       w := __ghdl_integer'[1];
       r := w;
     END;
   ELSE
     IF b3 THEN
       DECLARE
         LOCAL VAR w : __ghdl_integer;
       BEGIN
         w := __ghdl_integer'[2];
         r := w;
       END;
     ELSE
     END IF;
   END IF;
  ELSE
     DECLARE
       LOCAL VAR w : __ghdl_integer;
     BEGIN
       w := __ghdl_integer'[3];
       r := w;
     END;
  END IF;
  RETURN r; 
END;
