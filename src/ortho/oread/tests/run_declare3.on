TYPE __ghdl_int IS UNSIGNED (32);

PUBLIC FUNCTION main (a : __ghdl_int) RETURN __ghdl_int
DECLARE
  LOCAL VAR b : __ghdl_int;
  LOCAL VAR z : __ghdl_int;
BEGIN
  b := a;
  DECLARE
    LOCAL VAR g : __ghdl_int;
    LOCAL VAR c : __ghdl_int;
  BEGIN
    c := b;
    g := c;
    z := g +# c;
  END;
  RETURN z +# 1;
END;
