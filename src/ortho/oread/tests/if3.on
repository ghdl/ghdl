TYPE __ghdl_bool_type IS BOOLEAN {false, true};
TYPE __ghdl_integer IS SIGNED (32);

PUBLIC FUNCTION test_arg (v : __ghdl_bool_type) RETURN __ghdl_integer
DECLARE
  LOCAL VAR r : __ghdl_integer;
BEGIN
  r := __ghdl_integer'[0];
  IF v THEN
   DECLARE
     LOCAL VAR w : __ghdl_integer;
   BEGIN
     w := __ghdl_integer'[1];
     r := w;
   END;
  END IF;
  RETURN r; 
END;
